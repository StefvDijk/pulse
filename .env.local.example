# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Hevy (webhook signature verification)
HEVY_WEBHOOK_SECRET=whsec_...

# Strava OAuth (developers.strava.com → My API Application)
# Required scope for activity ingest: activity:read_all
STRAVA_CLIENT_ID=...
STRAVA_CLIENT_SECRET=...
# Must match the "Authorization Callback Domain" set on your Strava app.
# Local dev → http://localhost:3000/api/strava/oauth/callback
# Production → https://<your-domain>/api/strava/oauth/callback
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/oauth/callback

# Vercel Cron (set a random secret, use it in Authorization: Bearer <secret>)
CRON_SECRET=...

# NOTE: Health Auto Export token is NOT a fixed env var.
# Each user configures their own token in Settings > Koppelingen.
# That token is stored in user_settings.health_auto_export_token and
# verified per-request against the database.
