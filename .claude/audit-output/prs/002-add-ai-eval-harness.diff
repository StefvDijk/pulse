+#!/usr/bin/env tsx
+/**
+ * Pulse AI eval harness.
+ *
+ * Usage:
+ *   pnpm eval:ai                   # runs all cases
+ *   pnpm eval:ai --category=plan   # filter by category
+ *   pnpm eval:ai --fail-on=85      # exit 1 if pass rate < 85%
+ *
+ * What it tests:
+ *   1. classifier.ts: classify(text) → expected message_type
+ *   2. /api/chat: full pipeline including tool routing
+ *   3. Token budget: assert each request stays under TOKEN_BUDGET
+ *
+ * Output:
+ *   .claude/audit-output/data/eval-results-<timestamp>.json
+ */
+import { readFileSync, writeFileSync, mkdirSync } from 'node:fs'
+import { join } from 'node:path'
+import { classify } from '@/lib/ai/classifier'
+
+interface EvalCase {
+  id: string
+  category: 'nutrition_log' | 'injury_log' | 'schema_change' | 'memory' | 'plan' | 'analysis' | 'general_chat' | 'question'
+  input: string
+  expectedType: string
+  mustContain?: string[]
+  mustNotContain?: string[]
+  expectedTool?: string
+}
+
+interface EvalResult {
+  case: EvalCase
+  actualType: string
+  passed: boolean
+  reason?: string
+  durationMs: number
+}
+
+async function runClassifierCase(c: EvalCase): Promise<EvalResult> {
+  const start = Date.now()
+  const actualType = classify(c.input)
+  const passed = actualType === c.expectedType
+  return {
+    case: c,
+    actualType,
+    passed,
+    reason: passed ? undefined : `expected ${c.expectedType}, got ${actualType}`,
+    durationMs: Date.now() - start,
+  }
+}
+
+async function main() {
+  const argv = process.argv.slice(2)
+  const categoryFilter = argv.find((a) => a.startsWith('--category='))?.split('=')[1]
+  const failOn = Number(argv.find((a) => a.startsWith('--fail-on='))?.split('=')[1] ?? 85)
+
+  const casesPath = join(process.cwd(), 'tests/fixtures/ai-eval/cases.json')
+  const cases = JSON.parse(readFileSync(casesPath, 'utf-8')) as EvalCase[]
+  const filtered = categoryFilter ? cases.filter((c) => c.category === categoryFilter) : cases
+
+  console.log(`\nRunning ${filtered.length} cases (filter: ${categoryFilter ?? 'all'})\n`)
+
+  const results: EvalResult[] = []
+  for (const c of filtered) {
+    const r = await runClassifierCase(c)
+    results.push(r)
+    const icon = r.passed ? '✅' : '❌'
+    console.log(`${icon} [${c.category.padEnd(15)}] ${c.id.padEnd(20)} ${r.reason ?? 'ok'}`)
+  }
+
+  const passed = results.filter((r) => r.passed).length
+  const passRate = (passed / results.length) * 100
+
+  console.log(`\n${passed}/${results.length} passed (${passRate.toFixed(1)}%)\n`)
+
+  // Persist for CI artifact / trend
+  const outDir = join(process.cwd(), '.claude/audit-output/data')
+  mkdirSync(outDir, { recursive: true })
+  const outPath = join(outDir, `eval-results-${Date.now()}.json`)
+  writeFileSync(outPath, JSON.stringify({ passRate, results }, null, 2))
+  console.log(`Report written to ${outPath}`)
+
+  if (passRate < failOn) {
+    console.error(`\nFAILED: pass rate ${passRate.toFixed(1)}% < threshold ${failOn}%`)
+    process.exit(1)
+  }
+}
+
+main().catch((err) => {
+  console.error(err)
+  process.exit(1)
+})

