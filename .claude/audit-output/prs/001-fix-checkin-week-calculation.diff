diff --git a/tests/check-in-week-calc.test.ts b/tests/check-in-week-calc.test.ts
new file mode 100644
--- /dev/null
+++ b/tests/check-in-week-calc.test.ts
@@ -0,0 +1,68 @@
+import { describe, expect, it } from 'vitest'
+import {
+  currentWeekStart,
+  nextWeekStart,
+  weekEnd,
+  isoWeekNumber,
+  isFutureWeek,
+} from '@/lib/dates/week'
+
+describe('currentWeekStart (Europe/Amsterdam)', () => {
+  it('zondag 21:00 lokaal → Monday of the just-finished ISO-week', () => {
+    // 2026-05-10 21:00 Amsterdam CEST = 19:00 UTC
+    expect(currentWeekStart(new Date('2026-05-10T19:00:00Z'))).toBe('2026-05-04')
+  })
+
+  it('maandag 01:30 CEST lokaal → Monday of the NEW ISO-week (off-by-one fix)', () => {
+    // 2026-05-11 01:30 CEST = 2026-05-10 23:30 UTC
+    // Buggy UTC-impl returned 2026-05-04; correct is 2026-05-11.
+    expect(currentWeekStart(new Date('2026-05-10T23:30:00Z'))).toBe('2026-05-11')
+  })
+
+  it('DST start zondag 29 maart 2026 03:00 lokaal → Monday 23 maart', () => {
+    // CEST begins this morning; clock jumps 02:00 → 03:00.
+    expect(currentWeekStart(new Date('2026-03-29T01:30:00Z'))).toBe('2026-03-23')
+  })
+
+  it('DST eind zondag 25 oktober 2026 02:30 lokaal → Monday 19 oktober', () => {
+    // CEST ends this morning; clock jumps 03:00 → 02:00.
+    expect(currentWeekStart(new Date('2026-10-25T00:30:00Z'))).toBe('2026-10-19')
+  })
+
+  it('donderdag → Maandag van diezelfde ISO-week', () => {
+    expect(currentWeekStart(new Date('2026-05-14T12:00:00Z'))).toBe('2026-05-11')
+  })
+})
+
+describe('nextWeekStart', () => {
+  it('voegt 7 dagen toe over DST start heen', () => {
+    expect(nextWeekStart('2026-03-23')).toBe('2026-03-30')
+  })
+  it('voegt 7 dagen toe over DST eind heen', () => {
+    expect(nextWeekStart('2026-10-19')).toBe('2026-10-26')
+  })
+  it('voegt 7 dagen toe over jaargrens heen', () => {
+    expect(nextWeekStart('2026-12-28')).toBe('2027-01-04')
+  })
+})
+
+describe('weekEnd', () => {
+  it('zondag van de week voor de gegeven maandag', () => {
+    expect(weekEnd('2026-05-04')).toBe('2026-05-10')
+    expect(weekEnd('2026-12-28')).toBe('2027-01-03')
+  })
+})
+
+describe('isoWeekNumber', () => {
+  it('week 53 voor 2026, week 1 voor 2027', () => {
+    expect(isoWeekNumber('2026-12-28')).toEqual({ weekNumber: 53, year: 2026 })
+    expect(isoWeekNumber('2027-01-04')).toEqual({ weekNumber: 1, year: 2027 })
+  })
+})
+
+describe('isFutureWeek', () => {
+  it('returns true when weekStart is strictly after current week', () => {
+    const today = new Date('2026-05-13T12:00:00Z') // Wednesday of week starting May 11
+    expect(isFutureWeek('2026-05-11', today)).toBe(false) // same week
+    expect(isFutureWeek('2026-05-18', today)).toBe(true)
+    expect(isFutureWeek('2026-05-04', today)).toBe(false) // past
+  })
+})
