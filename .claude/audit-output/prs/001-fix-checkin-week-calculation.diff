--- /dev/null
+++ b/src/lib/dates/week.ts
@@ -0,0 +1,40 @@
+import { TZDate } from '@date-fns/tz'
+import {
+  addDays,
+  endOfWeek,
+  format,
+  getISOWeek,
+  getISOWeekYear,
+  startOfWeek,
+} from 'date-fns'
+
+const TIMEZONE = 'Europe/Amsterdam'
+
+/** Monday of the ISO-week containing `now`, in YYYY-MM-DD (Europe/Amsterdam). */
+export function currentWeekStart(now: Date = new Date()): string {
+  const local = new TZDate(now, TIMEZONE)
+  const monday = startOfWeek(local, { weekStartsOn: 1 })
+  return format(monday, 'yyyy-MM-dd')
+}
+
+/** Sunday of the ISO-week for the given Monday, in YYYY-MM-DD. */
+export function weekEnd(weekStart: string): string {
+  const start = new TZDate(`${weekStart}T00:00:00`, TIMEZONE)
+  return format(endOfWeek(start, { weekStartsOn: 1 }), 'yyyy-MM-dd')
+}
+
+/** weekStart + 7 days, robust over DST transitions, in YYYY-MM-DD. */
+export function nextWeekStart(weekStart: string): string {
+  const start = new TZDate(`${weekStart}T00:00:00`, TIMEZONE)
+  return format(addDays(start, 7), 'yyyy-MM-dd')
+}
+
+export function isoWeekNumber(weekStart: string): { weekNumber: number; year: number } {
+  const start = new TZDate(`${weekStart}T00:00:00`, TIMEZONE)
+  return { weekNumber: getISOWeek(start), year: getISOWeekYear(start) }
+}
+
+/** Returns true when `weekStart` is strictly after the current ISO-week's Monday. */
+export function isFutureWeek(weekStart: string, now: Date = new Date()): boolean {
+  return weekStart > currentWeekStart(now)
+}

